# ============================================================
# .env.example — Copia este archivo como .env y completa los valores
# NUNCA subas el archivo .env real a Git
# ============================================================

# ============================================================
# DISCORD — OBLIGATORIO
# ============================================================

# Token del bot (Discord Developer Portal → Tu aplicación → Bot → Token)
DISCORD_TOKEN=

# ID de tu aplicación/bot (Discord Developer Portal → Tu aplicación → General → Application ID)
DISCORD_CLIENT_ID=

# ID del servidor donde probar comandos (clic derecho en el servidor → Copiar ID)
# Si se define: los comandos se registran SOLO en ese servidor (instantáneo, ideal para desarrollo)
# Si no se define: los comandos se registran globalmente (puede tardar ~1 hora)
DISCORD_GUILD_ID=

# ============================================================
# LAVALINK — OBLIGATORIO
# ============================================================

# Contraseña del servidor Lavalink (debe coincidir con application.yml)
# Cambia este valor en producción por algo seguro
LAVALINK_PASSWORD=youshallnotpass

# En Docker Compose, el host es el nombre del servicio "lavalink"
# Si corres Lavalink fuera de Docker, usa "localhost" o la IP del servidor
LAVALINK_HOST=lavalink

# Puerto de Lavalink (por defecto 2333)
LAVALINK_PORT=2333

# Usar conexión segura (WSS/HTTPS) — solo si Lavalink tiene SSL configurado
LAVALINK_SECURE=false

# ============================================================
# SPOTIFY — OPCIONAL pero RECOMENDADO para soporte completo de Spotify
# ============================================================
# Cómo obtener:
#   1. Ve a https://developer.spotify.com/dashboard
#   2. Crea una aplicación
#   3. Copia el Client ID y Client Secret
#
# IMPORTANTE: Solo se usa para leer metadata (Client Credentials Flow)
# NO se accede a ninguna cuenta de usuario ni se extrae audio de Spotify
# ============================================================

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ============================================================
# COMPORTAMIENTO DEL BOT — OPCIONAL (tiene valores por defecto)
# ============================================================

# Volumen inicial al unirse a un canal (1-150, por defecto 80)
DEFAULT_VOLUME=80

# Máximo de canciones en la cola por servidor (por defecto 500)
MAX_QUEUE_SIZE=500

# Milisegundos antes de auto-desconectarse cuando la cola está vacía
# 300000 = 5 minutos. 0 = nunca auto-desconectar
AUTO_DISCONNECT_MS=300000

# Plataforma de búsqueda por defecto para búsquedas de texto
# Opciones: ytmsearch (YouTube Music), ytsearch (YouTube), scsearch (SoundCloud)
DEFAULT_SEARCH_PLATFORM=ytmsearch

# Color principal de los embeds en hexadecimal (sin #)
EMBED_COLOR=5865F2

# ============================================================
# NODE.JS
# ============================================================

# Entorno de ejecución: "development" o "production"
NODE_ENV=production
